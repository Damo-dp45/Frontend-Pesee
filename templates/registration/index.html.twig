{% extends 'app-base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-brand">
        <div class="auth-brand__content">
            <div class="auth-brand__logo">
                <svg viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2"/>
                </svg>
            </div>
            <h1 class="auth-brand__title">Nouvelle entreprise</h1>
            <p class="auth-brand__desc">
                Créez un espace entreprise et associez-lui un administrateur qui gérera les accès et les données.
            </p>
            <div class="auth-brand__steps">
                <div class="auth-brand__step">
                    <span class="auth-brand__step-num">1</span>
                    <span>Définissez le code entreprise — il servira à lier les ponts bascule</span>
                </div>
                <div class="auth-brand__step">
                    <span class="auth-brand__step-num">2</span>
                    <span>Créez le compte administrateur associé</span>
                </div>
                <div class="auth-brand__step">
                    <span class="auth-brand__step-num">3</span>
                    <span>L'administrateur peut ensuite inviter ses utilisateurs</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-form-box auth-form-box--wide">

            <div class="auth-form-box__header">
                <h2 class="auth-form-box__title">Créer une entreprise</h2>
                <p class="auth-form-box__subtitle">
                    Accès réservé aux super administrateurs
                </p>
            </div>
            {#
                {% if success is defined and success %}
                    <div class="auth-alert auth-alert--success">
                        <svg viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                        {{ success }}
                    </div>
                {% endif %}
            #}
            {% if errors.global is defined %}
                <div class="auth-alert auth-alert--error">
                    <svg viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {{ errors.global }}
                </div>
            {% endif %}

            <form method="POST" class="auth-form">

                {# ── Entreprise ── #}
                <div class="auth-section">
                    <h3 class="auth-section__title">
                        <svg viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                        </svg>
                        Entreprise
                    </h3>

                    <div class="auth-grid">
                        <div class="auth-field">
                            <label class="auth-field__label" for="codeentreprise">
                                Code entreprise
                                <span class="auth-field__hint">Lié aux ponts bascule</span>
                            </label>
                            <input class="auth-field__input auth-field__code {% if errors.codeentreprise is defined %}auth-field__input--error{% endif %}"
                                   type="text" id="codeentreprise" name="codeentreprise"
                                   placeholder="SOF"
                                   value="{{ data.codeentreprise ?? '' }}"
                                   required>
                            {% if errors.codeentreprise is defined %}
                                <span class="auth-field__error">{{ errors.codeentreprise }}</span>
                            {% else %}
                                <span class="auth-field__desc">2 à 6 lettres majuscules</span>
                            {% endif %}
                        </div>

                        <div class="auth-field">
                            <label class="auth-field__label" for="nomentreprise">Nom de l'entreprise</label>
                            <input class="auth-field__input {% if errors.nomentreprise is defined %}auth-field__input--error{% endif %}"
                                   type="text" id="nomentreprise" name="nomentreprise"
                                   placeholder="SOFACI PESAGE"
                                   value="{{ data.nomentreprise ?? '' }}"
                                   required>
                            {% if errors.nomentreprise is defined %}
                                <span class="auth-field__error">{{ errors.nomentreprise }}</span>
                            {% endif %}
                        </div>

                        <div class="auth-field">
                            <label class="auth-field__label" for="adresse">
                                Adresse
                                <span class="auth-field__optional">Optionnel</span>
                            </label>
                            <input class="auth-field__input" type="text"
                                   id="adresse" name="adresse"
                                   placeholder="Abidjan, Plateau"
                                   value="{{ data.adresse ?? '' }}">
                        </div>

                        <div class="auth-field">
                            <label class="auth-field__label" for="contact">
                                Contact
                                <span class="auth-field__optional">Optionnel</span>
                            </label>
                            <input class="auth-field__input" type="text"
                                   id="contact" name="contact"
                                   placeholder="+225 07 00 00 00 00"
                                   value="{{ data.contact ?? '' }}">
                        </div>
                    </div>
                </div>

                {# ── Administrateur ── #}
                <div class="auth-section">
                    <h3 class="auth-section__title">
                        <svg viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        Administrateur
                    </h3>

                    <div class="auth-grid">
                        <div class="auth-field">
                            <label class="auth-field__label" for="nom">Nom</label>
                            <input class="auth-field__input {% if errors.nom is defined %}auth-field__input--error{% endif %}"
                                   type="text" id="nom" name="nom"
                                   placeholder="KOUASSI"
                                   value="{{ data.nom ?? '' }}"
                                   required>
                            {% if errors.nom is defined %}
                                <span class="auth-field__error">{{ errors.nom }}</span>
                            {% endif %}
                        </div>

                        <div class="auth-field">
                            <label class="auth-field__label" for="prenom">Prénom</label>
                            <input class="auth-field__input {% if errors.prenom is defined %}auth-field__input--error{% endif %}"
                                   type="text" id="prenom" name="prenom"
                                   placeholder="Jean"
                                   value="{{ data.prenom ?? '' }}"
                                   required>
                            {% if errors.prenom is defined %}
                                <span class="auth-field__error">{{ errors.prenom }}</span>
                            {% endif %}
                        </div>

                        <div class="auth-field auth-field--full">
                            <label class="auth-field__label" for="email">Adresse email</label>
                            <input class="auth-field__input {% if errors.email is defined %}auth-field__input--error{% endif %}"
                                   type="email" id="email" name="email"
                                   placeholder="admin@sofaci.com"
                                   value="{{ data.email ?? '' }}"
                                   autocomplete="email"
                                   required>
                            {% if errors.email is defined %}
                                <span class="auth-field__error">{{ errors.email }}</span>
                            {% endif %}
                        </div>

                        <div class="auth-field">
                            <label class="auth-field__label" for="password">Mot de passe</label>
                            <div class="auth-field__input-wrap">
                                <input class="auth-field__input {% if errors.password is defined %}auth-field__input--error{% endif %}"
                                       type="password" id="password" name="password"
                                       placeholder="••••••••"
                                       autocomplete="new-password"
                                       required>
                                <button type="button" class="auth-field__eye" id="toggle-password">
                                    <svg id="eye-show" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                    <svg id="eye-hide" viewBox="0 0 24 24" stroke-width="2" style="display:none">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                    </svg>
                                </button>
                            </div>
                            {% if errors.password is defined %}
                                <span class="auth-field__error">{{ errors.password }}</span>
                            {% else %}
                                <span class="auth-field__desc">Minimum 8 caractères</span>
                            {% endif %}
                        </div>

                        <div class="auth-field">
                            <label class="auth-field__label" for="password_confirm">Confirmer</label>
                            <input class="auth-field__input {% if errors.password_confirm is defined %}auth-field__input--error{% endif %}"
                                   type="password" id="password_confirm" name="password_confirm"
                                   placeholder="••••••••"
                                   autocomplete="new-password"
                                   required>
                            {% if errors.password_confirm is defined %}
                                <span class="auth-field__error">{{ errors.password_confirm }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <button type="submit" class="auth-btn">Créer l'entreprise</button>

            </form>

            <p class="auth-form-box__footer">
                <a href="{{ path('home') }}" class="auth-link">← Retour au dashboard</a>
            </p>

        </div>
    </div>
</div>
{% endblock %}
